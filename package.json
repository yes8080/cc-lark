{
  "name": "cc-lark",
  "version": "0.1.2",
  "description": "Feishu/Lark MCP Server for Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cc-lark": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yes8080/cc-lark.git"
  },
  "bugs": {
    "url": "https://github.com/yes8080/cc-lark/issues"
  },
  "homepage": "https://github.com/yes8080/cc-lark#readme",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "feishu",
    "lark",
    "mcp",
    "claude-code"
  ],
  "license": "MIT"
}
